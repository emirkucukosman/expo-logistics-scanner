{
  "expo": {
    "name": "expo-logistics-scanner-example",
    "slug": "expo-logistics-scanner-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "expo.modules.logisticsscanner.example",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to scan barcodes."
      },
      "appleTeamId": "P5GE34PCWL"
    },
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "expo.modules.logisticsscanner.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
